{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "extends": ["ultracite/biome/core"],
  "files": {
    "includes": [
      "src/**/*.ts",
      "scripts/**/*.ts",
      "!node_modules/**/*",
      "!dist/**/*"
    ]
  },
  "javascript": {
    "globals": ["Bun"]
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noConsole": "off",
        "noEmptyBlockStatements": "off",
        "noExplicitAny": "warn",
        "useAwait": "warn"
      },
      "style": {
        "noMagicNumbers": "off",
        "noNonNullAssertion": "warn",
        "noNestedTernary": "warn",
        "useConsistentTypeDefinitions": {
          "level": "error",
          "options": {
            "style": "interface"
          }
        }
      },
      "complexity": {
        "noExcessiveCognitiveComplexity": "warn"
      },
      "correctness": {
        "noUndeclaredVariables": {
          "level": "error",
          "options": {
            "checkTypes": true
          }
        }
      },
      "performance": {
        "noNamespaceImport": "off",
        "noBarrelFile": "off",
        "useTopLevelRegex": "warn"
      }
    }
  }
}
